---
interface Props {
  text: string;
  icon?: string;
  class?: string;
}

const { text, icon, class: className = '' } = Astro.props;
---

<div class={`inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-primary text-primary rounded-md shadow-md font-medium text-sm ${className}`}>
  {icon && (
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
      <path d={icon} />
    </svg>
  )}
  <span>{text}</span>
</div>
