---
import menuData from '../data/menu.json';
import MenuCard from './MenuCard.astro';
import type { MenuData } from '../types/menu';

// Filter menu items for daily specials
const menu = menuData as MenuData;
const dailySpecials = menu.categories
  .flatMap(category => category.items)
  .filter(item => item.isDailySpecial === true);
---

{dailySpecials.length > 0 && (
  <section class="bg-primary text-cream py-12 md:py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-3">
          Menú del Día
        </h2>
        <p class="text-lg text-cream/90 max-w-2xl mx-auto">
          Platos especiales preparados frescos cada día. Sabores auténticos de la cocina Peruana y Argentina.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {dailySpecials.map((item) => (
          <MenuCard item={item} highlight={true} />
        ))}
      </div>

      <div class="text-center mt-8">
        <p class="text-cream/80 text-sm">
          Disponibles hasta agotar stock. Consultá por WhatsApp para hacer tu pedido.
        </p>
      </div>
    </div>
  </section>
)}
