---
import menuData from '../data/menu.json';
import type { MenuData } from '../types/menu';

// Filter menu items for daily specials
const menu = menuData as MenuData;
const dailySpecials = menu.categories
  .flatMap(category => category.items)
  .filter(item => item.isDailySpecial === true);
---

{dailySpecials.length > 0 && (
  <section class="bg-cream text-primary py-12 md:py-16 overflow-hidden">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-3">
          Menú del Día
        </h2>
        <p class="text-lg text-primary/80 max-w-2xl mx-auto">
          Platos especiales preparados frescos cada día. Sabores auténticos de la cocina Peruana y Argentina.
        </p>
      </div>

      <!-- Carousel Container -->
      <div class="relative max-w-6xl mx-auto">
        <div class="carousel-wrapper overflow-hidden">
          <div class="carousel-track flex transition-transform duration-500 ease-in-out">
            {dailySpecials.map((item, index) => (
              <div class="carousel-slide flex-shrink-0 w-full md:w-1/2 lg:w-1/3 px-2" data-slide={index}>
                <div class="bg-white rounded-xl shadow-lg overflow-hidden h-full hover:shadow-xl transition-shadow">
                  <div class="aspect-[16/10] overflow-hidden">
                    <img
                      src={item.image}
                      alt={item.name}
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-3 text-center">
                    <h3 class="text-lg font-serif font-bold text-primary">{item.name}</h3>
                    <p class="text-xs text-primary/70 mt-1 line-clamp-2">{item.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Navigation Dots -->
        <div class="flex justify-center gap-2 mt-6" id="carousel-dots-container">
          <!-- Dots will be generated dynamically by JavaScript based on screen size -->
        </div>
      </div>

      <div class="text-center mt-8">
        <p class="text-primary/70 text-sm">
          Consultá disponibilidad del día por WhatsApp
        </p>
      </div>
    </div>
  </section>
)}

<style>
  .carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(85, 107, 47, 0.3);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .carousel-dot:hover {
    background-color: rgba(85, 107, 47, 0.5);
    transform: scale(1.2);
  }

  .carousel-dot.active {
    background-color: rgba(85, 107, 47, 0.9);
    width: 32px;
    border-radius: 6px;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Carousel functionality
  function initCarousel() {
    const track = document.querySelector('.carousel-track') as HTMLElement;
    const slides = document.querySelectorAll('.carousel-slide');
    const dotsContainer = document.getElementById('carousel-dots-container');
    let currentIndex = 0;
    let autoplayInterval: number;
    let dots: NodeListOf<HTMLElement> | null = null;

    if (!track || slides.length === 0 || !dotsContainer) return;

    // Determine number of visible slides based on screen size
    function getVisibleSlides(): number {
      const width = window.innerWidth;
      if (width >= 1024) return 3; // lg: 3 slides
      if (width >= 768) return 2;  // md: 2 slides
      return 1; // mobile: 1 slide
    }

    // Generate navigation dots based on current screen size
    function generateDots() {
      const visibleSlides = getVisibleSlides();
      const maxIndex = Math.max(0, slides.length - visibleSlides);
      const numDots = maxIndex + 1; // Number of valid positions

      // Clear existing dots
      dotsContainer!.innerHTML = '';

      // Create new dots
      for (let i = 0; i <= maxIndex; i++) {
        const button = document.createElement('button');
        button.className = 'carousel-dot';
        button.setAttribute('data-slide-to', i.toString());
        button.setAttribute('aria-label', `Ir al plato ${i + 1}`);

        const span = document.createElement('span');
        span.className = 'sr-only';
        span.textContent = `Plato ${i + 1}`;
        button.appendChild(span);

        button.addEventListener('click', () => {
          stopAutoplay();
          updateCarousel(i);
          startAutoplay();
        });

        dotsContainer!.appendChild(button);
      }

      // Update dots reference
      dots = dotsContainer!.querySelectorAll('.carousel-dot');
    }

    function updateCarousel(index: number) {
      const visibleSlides = getVisibleSlides();
      const maxIndex = Math.max(0, slides.length - visibleSlides);

      // Clamp index to valid range
      currentIndex = Math.max(0, Math.min(index, maxIndex));

      // Calculate offset
      const slideWidth = slides[0].clientWidth;
      const offset = -currentIndex * slideWidth;
      track.style.transform = `translateX(${offset}px)`;

      // Update dots
      if (dots) {
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }
    }

    function nextSlide() {
      const visibleSlides = getVisibleSlides();
      const maxIndex = Math.max(0, slides.length - visibleSlides);

      if (currentIndex >= maxIndex) {
        currentIndex = 0;
      } else {
        currentIndex++;
      }

      updateCarousel(currentIndex);
    }

    function startAutoplay() {
      stopAutoplay(); // Clear any existing interval
      autoplayInterval = window.setInterval(nextSlide, 4500);
    }

    function stopAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
      }
    }

    // Handle window resize
    let resizeTimeout: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = window.setTimeout(() => {
        generateDots(); // Regenerate dots for new screen size
        updateCarousel(currentIndex); // Update position
      }, 250);
    });

    // Initialize
    generateDots(); // Generate initial dots
    updateCarousel(0);
    startAutoplay();

    // Pause on hover
    const carouselWrapper = document.querySelector('.carousel-wrapper');
    if (carouselWrapper) {
      carouselWrapper.addEventListener('mouseenter', stopAutoplay);
      carouselWrapper.addEventListener('mouseleave', startAutoplay);
    }

    // Cleanup on page unload
    window.addEventListener('beforeunload', stopAutoplay);
  }

  // Initialize carousel when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }
</script>
