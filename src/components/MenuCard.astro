---
import type { MenuItem } from '../types/menu';

interface Props {
  item: MenuItem;
  highlight?: boolean;
}

const { item, highlight = false } = Astro.props;

// Format price from cents to dollars (e.g., 4500 → $45.00)
const formattedPrice = `$${(item.price / 100).toFixed(2)}`;

// Allergen icons mapping
const allergenLabels: Record<string, string> = {
  gluten: 'Gluten',
  dairy: 'Lácteos',
  nuts: 'Frutos secos',
  shellfish: 'Mariscos',
  soy: 'Soja',
  eggs: 'Huevo',
};
---

<div class={`group relative bg-white rounded-lg shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden ${highlight ? 'ring-2 ring-primary' : ''}`}>
  <!-- Image Section -->
  <div class="relative h-48 bg-gray-200 overflow-hidden">
    <!-- Placeholder for now - will use Astro Image when real photos available -->
    <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-cream to-cream-dark">
      <svg class="w-20 h-20 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
    {highlight && (
      <div class="absolute top-2 right-2 bg-primary text-cream px-3 py-1 rounded-full text-xs font-bold shadow-lg">
        Menú del Día
      </div>
    )}
  </div>

  <!-- Content Section -->
  <div class="p-4">
    <!-- Name -->
    <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary transition-colors">
      {item.name}
    </h3>

    <!-- Description -->
    <p class="text-sm text-gray-600 mb-3 line-clamp-2">
      {item.description}
    </p>

    <!-- Allergens (if present) -->
    {item.allergens && item.allergens.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-3">
        {item.allergens.map((allergen) => (
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-yellow-100 text-yellow-800 border border-yellow-200">
            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            {allergenLabels[allergen] || allergen}
          </span>
        ))}
      </div>
    )}

    <!-- Price -->
    <div class="flex items-center justify-between">
      <span class="text-2xl font-bold text-primary-dark">
        {formattedPrice}
      </span>
      {item.isDailySpecial && (
        <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      )}
    </div>
  </div>
</div>
