---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { MenuItem } from '../types/menu';

interface Props {
  item: MenuItem;
  highlight?: boolean;
  image?: ImageMetadata | null;
}

const { item, highlight = false, image } = Astro.props;

const formattedPrice = `AR$ ${item.price.toLocaleString('es-AR')}`;
---

<div class={`group relative bg-cream/90 hover:bg-cream rounded-2xl overflow-hidden h-full flex flex-col transition-all duration-300 ${highlight ? 'overflow-hidden' : 'overflow-hidden'}`}>
  <div class="absolute top-[-1px] bottom-[-1px] left-0 w-1.5 bg-[#556B2F] z-10"></div>

  <!-- Imagen -->
  <div class="relative aspect-square overflow-hidden flex-shrink-0">
    {image ? (
      <Image
        src={image}
        alt={item.name}
        width={400}
        height={400}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-cream to-cream-dark">
        <svg class="w-16 h-16 text-primary/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    {highlight && (
      <div class="absolute top-2 right-2 bg-primary text-cream px-2.5 py-1 rounded-full text-xs font-bold shadow-md">
        Recomendación de la Chef
      </div>
    )}
  </div>

  <!-- Contenido -->
  <div class="p-4 flex-1 flex flex-col">
    <div class="flex-1">
      <h3 class="text-base font-serif font-bold text-primary mb-1 group-hover:text-primary/80 transition-colors leading-snug">
        {item.name}
      </h3>
      {item.description && (
        <p class="text-xs text-gray-500 leading-relaxed">
          {item.description}
        </p>
      )}
    </div>
    <div class="mt-3 pt-3 border-t border-primary/10">
      <span class="text-lg font-bold text-primary">
        {formattedPrice}
      </span>
    </div>
  </div>
</div>
