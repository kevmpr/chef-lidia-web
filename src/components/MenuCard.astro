---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { MenuItem } from '../types/menu';

interface Props {
  item: MenuItem;
  highlight?: boolean;
  image?: ImageMetadata | null;
}

const { item, highlight = false, image } = Astro.props;

// Format price in Argentine Pesos with thousands separator (e.g., 22000 → AR$ 22.000)
const formattedPrice = `AR$ ${item.price.toLocaleString('es-AR')}`;
---

<div class={`group relative bg-white rounded-lg shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden h-full flex flex-col ${highlight ? 'ring-2 ring-primary' : ''}`}>
  <!-- Image Section -->
  <div class="relative aspect-square bg-gray-200 overflow-hidden flex-shrink-0">
    {image ? (
      <Image src={image} alt={item.name} width={400} height={400} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-cream to-cream-dark">
        <svg class="w-20 h-20 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    {highlight && (
      <div class="absolute top-2 right-2 bg-primary text-cream px-3 py-1 rounded-full text-xs font-bold shadow-lg">
        Recomendación de la Chef
      </div>
    )}
  </div>

  <!-- Content Section -->
  <div class="p-4 flex-1 flex flex-col">
    <!-- Text Area (grows to fill available space) -->
    <div class="flex-1">
      <!-- Name -->
      <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary transition-colors">
        {item.name}
      </h3>

      <!-- Description (no truncation) -->
      <p class="text-sm text-gray-600 mb-3">
        {item.description}
      </p>
    </div>

    <!-- Price (pushed to bottom) -->
    <div class="mt-auto">
      <span class="text-lg md:text-2xl font-bold text-primary-dark">
        {formattedPrice}
      </span>
    </div>
  </div>
</div>
