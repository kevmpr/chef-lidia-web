---
import { Image } from 'astro:assets';
import logo from '../assets/cheflidia-logo.png';

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/menu', label: 'Menú' },
  { href: '/empresas', label: 'Empresas' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<nav class="bg-white/95 backdrop-blur-sm shadow-sm border-b border-gray-100 sticky top-0 z-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center transition-transform duration-200 hover:scale-105">
        <Image
          src={logo}
          alt="Chef Lidia y Familia"
          width={150}
          height={60}
          class="h-12 w-auto md:h-16"
        />
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center space-x-1 lg:space-x-2">
        {navItems.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`px-4 lg:px-5 py-2 text-sm lg:text-base font-medium rounded-md transition-all duration-200 ${
                currentPath === href
                  ? 'text-primary font-semibold'
                  : 'text-gray-700 hover:text-primary hover:bg-cream/30'
              }`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2.5 rounded-lg text-gray-700 hover:text-primary hover:bg-cream/50 focus:outline-none focus:ring-2 focus:ring-primary/30 transition-all duration-200"
        aria-label="Toggle menu"
      >
        <svg
          class="w-6 h-6 transition-transform duration-200"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            id="menu-icon"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 pt-2">
      <ul class="space-y-1">
        {navItems.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`block px-4 py-3 text-base font-medium rounded-lg transition-all duration-200 border-l-4 ${
                currentPath === href
                  ? 'text-primary border-primary bg-cream/30 font-semibold'
                  : 'text-gray-700 border-transparent hover:text-primary hover:bg-cream/20 hover:border-primary/20'
              }`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle with icon animation
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  button?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');

    // Animate menu icon
    if (menuIcon) {
      if (isHidden) {
        menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      } else {
        menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
      }
    }
  });
</script>
