---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const contactInfo = {
  address: {
    street: 'Av Colonia 95',
    neighborhood: 'Parque Patricios',
    city: 'Ciudad Autónoma de Buenos Aires',
    postalCode: 'C1437',
  },
  phone: '+54 9 11 2824-0324',
  email: 'cheflidiayfamilia@gmail.com',
  hours: {
    weekday: 'Lunes a Viernes: 11:00 - 15:30 hs',
    weekend: 'Viernes y Sábado: 19:00 - 00:00 hs',
  },
  social: {
    instagram: 'https://instagram.com/chef.lidia',
    tiktok: 'https://tiktok.com/@chef.lidia',
  }
};
---

<Layout
  title="Contacto - Chef Lidia y Familia | Parque Patricios"
  description="Contactanos para pedidos, reservas o viandas corporativas. Av Colonia 95, Parque Patricios. WhatsApp, email e Instagram disponibles."
>
  <Navbar />

  <main class="bg-cream">

    <!-- Hero -->
    <section class="bg-cream pt-16 pb-12 md:pt-24 md:pb-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <span class="inline-block text-sm font-semibold tracking-widest text-[#556B2F] uppercase mb-5">Hablemos</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-primary leading-tight mb-5">
            Estamos a un mensaje de distancia.
          </h1>
          <p class="text-lg text-gray-600 leading-relaxed">
            Ya sea para un pedido puntual, una consulta de empresas o simplemente saber qué hay hoy en el menú — respondemos rápido.
          </p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="pb-20 md:pb-28 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">

          <!-- Left: Contact cards -->
          <div class="space-y-4">

            <!-- WhatsApp -->
            <a
              href="https://wa.me/5491128240324?text=Hola%20Lidia!%20Vi%20la%20web%20y%20me%20gustar%C3%ADa%20hacer%20una%20consulta"
              target="_blank"
              rel="noopener noreferrer"
              class="group relative flex items-start gap-5 bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100 overflow-hidden"
            >
              <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
              <div class="w-12 h-12 rounded-xl bg-[#556B2F]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#556B2F]/20 transition-colors">
                <svg class="w-6 h-6 text-[#556B2F]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold tracking-widest text-[#556B2F] uppercase mb-1">Más rápido</p>
                <h3 class="font-semibold text-lg text-gray-900 mb-0.5">WhatsApp</h3>
                <p class="text-gray-500 text-sm">{contactInfo.phone}</p>
              </div>
              <svg class="w-5 h-5 text-gray-300 group-hover:text-[#556B2F] transition-colors ml-auto self-center" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>

            <!-- Email -->
            <a
              href={`mailto:${contactInfo.email}`}
              class="group relative flex items-start gap-5 bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100 overflow-hidden"
            >
              <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
              <div class="w-12 h-12 rounded-xl bg-[#556B2F]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#556B2F]/20 transition-colors">
                <svg class="w-6 h-6 text-[#556B2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold tracking-widest text-[#556B2F] uppercase mb-1">Consultas y presupuestos</p>
                <h3 class="font-semibold text-lg text-gray-900 mb-0.5">Email</h3>
                <p class="text-gray-500 text-sm">{contactInfo.email}</p>
              </div>
              <svg class="w-5 h-5 text-gray-300 group-hover:text-[#556B2F] transition-colors ml-auto self-center" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>

            <!-- Instagram -->
            <a
              href={contactInfo.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative flex items-start gap-5 bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100 overflow-hidden"
            >
              <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
              <div class="w-12 h-12 rounded-xl bg-[#556B2F]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#556B2F]/20 transition-colors">
                <svg class="w-6 h-6 text-[#556B2F]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold tracking-widest text-[#556B2F] uppercase mb-1">Seguinos</p>
                <h3 class="font-semibold text-lg text-gray-900 mb-0.5">Instagram</h3>
                <p class="text-gray-500 text-sm">@chef.lidia</p>
              </div>
              <svg class="w-5 h-5 text-gray-300 group-hover:text-[#556B2F] transition-colors ml-auto self-center" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>

            <!-- TikTok -->
            <a
              href={contactInfo.social.tiktok}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative flex items-start gap-5 bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100 overflow-hidden"
            >
              <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
              <div class="w-12 h-12 rounded-xl bg-[#556B2F]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#556B2F]/20 transition-colors">
                <svg class="w-6 h-6 text-[#556B2F]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0011.14-4.02v-6.95a8.16 8.16 0 004.65 1.46v-3.9a4.84 4.84 0 01-1.2 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold tracking-widest text-[#556B2F] uppercase mb-1">Seguinos</p>
                <h3 class="font-semibold text-lg text-gray-900 mb-0.5">TikTok</h3>
                <p class="text-gray-500 text-sm">@chef.lidia</p>
              </div>
              <svg class="w-5 h-5 text-gray-300 group-hover:text-[#556B2F] transition-colors ml-auto self-center" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>

          </div>

          <!-- Right: Hours + Map -->
          <div class="space-y-6">

            <!-- Horarios -->
            <div class="relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100 overflow-hidden">
              <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
              <h2 class="text-xl font-serif font-bold text-primary mb-6">Horarios de Atención</h2>
              <div class="space-y-5">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-[#556B2F]/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-[#556B2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900 text-sm">{contactInfo.hours.weekday}</p>
                    <p class="text-xs text-gray-500 mt-0.5">Almuerzo y viandas corporativas</p>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-[#556B2F]/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-[#556B2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900 text-sm">{contactInfo.hours.weekend}</p>
                    <p class="text-xs text-gray-500 mt-0.5">Cena (solo fin de semana)</p>
                  </div>
                </div>
              </div>
              <div class="mt-6 pt-5 border-t border-gray-100">
                <p class="text-xs text-gray-500">
                  Para viandas corporativas, pedidos con 24 hs de anticipación.
                </p>
              </div>
            </div>

            <!-- Map -->
            <div class="relative bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
              <div class="p-6 pb-4">
                <div class="flex items-center gap-3 mb-1">
                  <svg class="w-5 h-5 text-[#556B2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <h3 class="font-semibold text-gray-900">Av Colonia 95, Parque Patricios</h3>
                </div>
                <p class="text-xs text-gray-500 ml-8">Ciudad Autónoma de Buenos Aires</p>
              </div>
              <div class="h-56">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.0!2d-58.4043!3d-34.6295!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bccb4b0f6e8b9f%3A0x1!2sAv.%20Colonia%2095%2C%20Parque%20Patricios%2C%20CABA!5e0!3m2!1ses-419!2sar!4v1700000000000!5m2!1ses-419!2sar"
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Ubicación Chef Lidia - Av Colonia 95, Parque Patricios"
                ></iframe>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <WhatsAppButton type="b2c" />
</Layout>
