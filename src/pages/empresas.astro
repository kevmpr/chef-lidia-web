---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import ReviewCard from '../components/ReviewCard.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

// Pricing tiers for corporate catering
const pricingTiers = [
  {
    range: '5-10 viandas',
    discount: '10% OFF',
    description: 'Ideal para equipos pequeños',
    features: ['Menú variado', 'Entrega programada', 'Factura C incluida']
  },
  {
    range: '11-20 viandas',
    discount: '15% OFF',
    description: 'Perfecto para equipos medianos',
    features: ['Menú variado', 'Entrega programada', 'Factura C incluida', 'Opciones vegetarianas']
  },
  {
    range: '21+ viandas',
    discount: 'Presupuesto personalizado',
    description: 'Para grandes empresas',
    features: ['Menú variado', 'Entrega programada', 'Factura C incluida', 'Opciones vegetarianas', 'Atención prioritaria']
  }
];

// Placeholder B2B testimonials
const testimonials = [
  {
    name: 'María González',
    company: 'TechHub Patricios',
    rating: 5,
    text: 'Llevamos 6 meses pidiendo viandas para el equipo. La calidad es excelente y la facturación sin problemas. ¡Muy recomendable!',
    date: 'Marzo 2026'
  },
  {
    name: 'Carlos Martínez',
    company: 'Estudio Creativo BA',
    rating: 5,
    text: 'La comida casera de Chef Lidia es lo que nuestro equipo necesitaba. Variedad, buen precio y entregas puntuales.',
    date: 'Febrero 2026'
  }
];
---

<Layout
  title="Viandas Corporativas en Parque Patricios - Chef Lidia"
  description="Servicio de viandas para empresas tech. Factura C, descuentos por volumen, entrega programada en Distrito Tecnológico. Comida casera peruana y argentina para tu equipo."
>
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Chef Lidia y Familia",
    "image": "/assets/cheflidia-logo.png",
    "description": "Servicio de viandas corporativas y comida casera peruana y argentina",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Av Colonia 95",
      "addressLocality": "Parque Patricios",
      "addressRegion": "CABA",
      "postalCode": "C1437",
      "addressCountry": "AR"
    },
    "telephone": "+54-9-11-2824-0324",
    "servedCuisine": ["Peruana", "Argentina"],
    "priceRange": "$$",
    "openingHours": ["Mo-Fr 11:00-15:30", "Fr-Sa 19:00-00:00"]
  })} />

  <Navbar />

  <main class="bg-cream">
    <!-- Hero Section with Factura C Badge -->
    <section class="relative bg-cream py-16 md:py-24 overflow-hidden">
      <!-- Factura C Badge - Prominent positioning -->
      <div class="absolute top-4 right-4 md:top-6 md:right-6 z-10">
        <Badge
          text="Factura C Incluida"
          class="text-base md:text-lg px-6 py-3 shadow-2xl animate-pulse"
        />
      </div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-0">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 text-primary">
            Viandas para tu equipo tech
          </h1>
          <p class="text-xl md:text-2xl mb-4 text-gray-800">
            Comida casera de calidad para empresas del Distrito Tecnológico
          </p>
          <p class="text-lg mb-8 text-gray-700">
            Alimentá a tu equipo con lo mejor de la cocina Peruana y Argentina. Menús variados, entregas programadas y facturación sin complicaciones.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button
              href="https://wa.me/5491128240324?text=Hola!%20Soy%20de%20[Empresa]%20en%20Parque%20Patricios.%20Me%20interesa%20el%20servicio%20de%20viandas%20corporativas.%20%C2%BFPodr%C3%ADan%20enviarme%20informaci%C3%B3n%20sobre%20precios%20y%20log%C3%ADstica%3F"
              variant="secondary"
              size="lg"
              class="inline-flex items-center gap-2"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Solicitar Presupuesto
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Indicators -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Factura C -->
          <div class="text-center">
            <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-cream" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-primary mb-2">Factura C</h3>
            <p class="text-gray-600">Facturación incluida sin cargos adicionales</p>
          </div>

          <!-- Distrito Tecnológico -->
          <div class="text-center">
            <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-cream" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-primary mb-2">Envíos al Distrito Tecnológico</h3>
            <p class="text-gray-600">Entregas programadas en Parque Patricios y zona</p>
          </div>

          <!-- Descuentos -->
          <div class="text-center">
            <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-cream" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-primary mb-2">Descuentos por Volumen</h3>
            <p class="text-gray-600">Hasta 15% OFF en pedidos grandes</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Tiers -->
    <section class="py-12 md:py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-3">
            Planes Corporativos
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Elegí el plan que mejor se adapte al tamaño de tu equipo
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {pricingTiers.map((tier, index) => (
            <div class={`bg-cream rounded-lg p-6 border-2 ${index === 1 ? 'border-primary shadow-xl scale-105' : 'border-gray-200'}`}>
              {index === 1 && (
                <div class="text-center mb-4">
                  <span class="inline-block bg-primary text-cream px-3 py-1 rounded-full text-xs font-bold">
                    MÁS POPULAR
                  </span>
                </div>
              )}
              <h3 class="text-2xl font-serif font-bold text-primary mb-2 text-center">
                {tier.range}
              </h3>
              <p class="text-center text-gray-600 mb-4">{tier.description}</p>
              <div class="text-center mb-6">
                <p class="text-3xl font-bold text-primary-dark">{tier.discount}</p>
              </div>
              <ul class="space-y-2 mb-6">
                {tier.features.map((feature) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-sm text-gray-700">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-3">
            Lo que dicen nuestros clientes
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {testimonials.map((review) => (
            <ReviewCard {...review} />
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-12 md:py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-8 text-center">
          Preguntas Frecuentes
        </h2>

        <div class="space-y-4">
          <details class="bg-cream p-6 rounded-lg group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Cuál es el horario de entrega?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Realizamos entregas de lunes a viernes entre las 11:00 y 14:00 hs. Podés programar tu pedido con 24hs de anticipación.
            </p>
          </details>

          <details class="bg-cream p-6 rounded-lg group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Cómo funciona el pedido mínimo?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              El pedido mínimo para empresas es de 5 viandas. A partir de ese número aplicamos descuentos progresivos.
            </p>
          </details>

          <details class="bg-cream p-6 rounded-lg group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Qué métodos de pago aceptan?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Aceptamos transferencia bancaria y Mercado Pago. Emitimos Factura C con todos los pedidos corporativos.
            </p>
          </details>

          <details class="bg-cream p-6 rounded-lg group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Tienen opciones vegetarianas?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Sí, contamos con opciones vegetarianas como tallarines verdes, causa limeña, y ensaladas. Consultá el menú completo al solicitar presupuesto.
            </p>
          </details>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-primary text-cream py-12 md:py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-bold mb-4">
          ¿Listo para alimentar a tu equipo?
        </h2>
        <p class="text-lg mb-6 text-cream/90 max-w-2xl mx-auto">
          Contactanos por WhatsApp y te armamos un presupuesto personalizado para tu empresa
        </p>
        <Button
          href="https://wa.me/5491128240324?text=Hola!%20Soy%20de%20[Empresa]%20en%20Parque%20Patricios.%20Me%20interesa%20el%20servicio%20de%20viandas%20corporativas.%20%C2%BFPodr%C3%ADan%20enviarme%20informaci%C3%B3n%20sobre%20precios%20y%20log%C3%ADstica%3F"
          variant="secondary"
          size="lg"
          class="inline-flex items-center gap-2"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar Presupuesto
        </Button>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton type="b2b" />
</Layout>
