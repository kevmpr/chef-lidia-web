---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import ReviewCard from '../components/ReviewCard.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

// Pricing tiers for corporate catering
const pricingTiers = [
  {
    range: '5-15 viandas',
    label: 'Menú Clásico',
    description: 'Ideal para equipos pequeños',
    features: ['Menú variado', 'Entrega programada', 'Factura C incluida', 'Menú vegetariano incluido']
  },
  {
    range: '15-30 viandas',
    label: 'Menú Especial',
    description: 'Perfecto para equipos medianos',
    features: ['Menú variado', 'Entrega programada', 'Factura C incluida', 'Menú vegetariano incluido', 'Priorización de pedidos']
  },
  {
    range: '+30 viandas',
    label: 'Menú Ejecutivo',
    description: 'Para equipos grandes',
    features: ['Menú variado', 'Entrega programada', 'Factura C incluida', 'Menú vegetariano incluido', 'Priorización de pedidos', 'Personalización de platos']
  }
];

const testimonials = [
  {
    name: 'María González',
    company: 'Consultora RH Soluciones',
    rating: 5,
    text: 'Llevamos 8 meses pidiendo viandas para todo el equipo. La calidad es excelente, la variedad no aburre y la facturación es impecable. Totalmente recomendable.',
    date: 'Marzo 2026'
  },
  {
    name: 'Carlos Martínez',
    company: 'Constructora Del Sur',
    rating: 5,
    text: 'Somos una empresa de construcción y necesitábamos algo práctico para los chicos en obra. Chef Lidia nos dio una solución a medida con entrega puntual y buena comida.',
    date: 'Febrero 2026'
  },
  {
    name: 'Valeria Ríos',
    company: 'Centro Médico Integral',
    rating: 5,
    text: 'El equipo de enfermería almuerza todos los días con Chef Lidia. Nos encanta la opción vegetariana y que siempre llegue a tiempo. Un servicio muy profesional.',
    date: 'Enero 2026'
  },
  {
    name: 'Sebastián Lara',
    company: 'Agencia Dental Odontogroup',
    rating: 5,
    text: 'Empezamos con 10 viandas y ahora pedimos más de 25. La comida es rica, el trato es excelente y nunca tuvimos un problema con la Factura C.',
    date: 'Diciembre 2025'
  }
];
---

<Layout
  title="Viandas Corporativas para Empresas - Chef Lidia"
  description="Servicio de viandas para empresas de todo rubro. Factura C, descuentos por volumen, entrega programada en Parque Patricios y zona. Comida casera peruana y argentina para tu equipo."
>
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Chef Lidia y Familia",
    "image": "/assets/cheflidia-logo.png",
    "description": "Servicio de viandas corporativas y comida casera peruana y argentina",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Av Colonia 95",
      "addressLocality": "Parque Patricios",
      "addressRegion": "CABA",
      "postalCode": "C1437",
      "addressCountry": "AR"
    },
    "telephone": "+54-9-11-2824-0324",
    "servedCuisine": ["Peruana", "Argentina"],
    "priceRange": "$$",
    "openingHours": ["Mo-Fr 11:00-15:30", "Fr-Sa 19:00-00:00"]
  })} />

  <Navbar />

  <main class="bg-cream">
    <!-- Hero Section with Factura C Badge -->
    <section class="relative bg-cream py-16 md:py-24 overflow-hidden">


      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-0">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 text-primary">
            Viandas para tu equipo
          </h1>
          <p class="text-xl md:text-2xl mb-4 text-gray-800">
            Comida casera de calidad para empresas de todo rubro
          </p>
          <p class="text-lg mb-8 text-gray-700">
            Alimentá a tu equipo con lo mejor de la cocina Peruana y Argentina. Menús variados, entregas programadas y facturación sin complicaciones.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button
              href="https://wa.me/5491128240324?text=Hola!%20Soy%20de%20[Empresa].%20Me%20interesa%20el%20servicio%20de%20viandas%20corporativas.%20%C2%BFPodr%C3%ADan%20enviarme%20informaci%C3%B3n%20sobre%20precios%20y%20log%C3%ADstica%3F"
              variant="secondary"
              size="lg"
              class="inline-flex items-center gap-2"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Solicitar Presupuesto
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Badges -->
    <section class="py-14 md:py-20 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-sm font-semibold tracking-widest text-[#556B2F] uppercase mb-2">Por qué elegirnos</p>
          <h2 class="text-2xl md:text-3xl font-serif font-bold text-gray-900">Servicio pensado para empresas</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">

          <!-- Factura C -->
          <div class="group relative bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
            <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
            <div class="p-8 pl-10">
              <div class="w-16 h-16 rounded-2xl bg-[#556B2F]/10 flex items-center justify-center mb-6 group-hover:bg-[#556B2F]/20 transition-colors duration-300">
                <svg class="w-9 h-9 text-[#556B2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <h3 class="text-xl font-serif font-bold text-gray-900 mb-2">Factura C</h3>
              <p class="text-gray-500 text-sm leading-relaxed">Facturación incluida en cada pedido, sin cargos adicionales ni papeleo.</p>
            </div>
          </div>

          <!-- Envíos -->
          <div class="group relative bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
            <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
            <div class="p-8 pl-10">
              <div class="w-16 h-16 rounded-2xl bg-[#556B2F]/10 flex items-center justify-center mb-6 group-hover:bg-[#556B2F]/20 transition-colors duration-300">
                <svg class="w-9 h-9 text-[#556B2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
                </svg>
              </div>
              <h3 class="text-xl font-serif font-bold text-gray-900 mb-2">Envíos Programados</h3>
              <p class="text-gray-500 text-sm leading-relaxed">Entrega puntual de lunes a viernes. Coordinamos el horario que mejor le venga a tu equipo.</p>
            </div>
          </div>

          <!-- Descuentos por Volumen -->
          <div class="group relative bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
            <div class="absolute inset-y-0 left-0 w-1.5 bg-[#556B2F] rounded-l-2xl"></div>
            <div class="p-8 pl-10">
              <div class="w-16 h-16 rounded-2xl bg-[#556B2F]/10 flex items-center justify-center mb-6 group-hover:bg-[#556B2F]/20 transition-colors duration-300">
                <svg class="w-9 h-9 text-[#556B2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" />
                </svg>
              </div>
              <h3 class="text-xl font-serif font-bold text-gray-900 mb-2">Descuentos por Volumen</h3>
              <p class="text-gray-500 text-sm leading-relaxed">Precios preferenciales para pedidos frecuentes. Consultá por tu tarifa.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Pricing Tiers -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-3">
            Planes Corporativos
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Elegí el plan que mejor se adapte al tamaño de tu equipo. A mayor volumen de pedido, mejores precios.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {pricingTiers.map((tier, index) => (
            <div class={`bg-white rounded-2xl p-6 border-2 ${index === 1 ? 'border-[#556B2F] shadow-xl scale-105' : 'border-gray-200 shadow-sm'}`}>
              {index === 1 && (
                <div class="text-center mb-4">
                  <span class="inline-block bg-[#556B2F] text-[#FDF5E6] px-3 py-1 rounded-full text-xs font-bold tracking-wide">
                    MÁS POPULAR
                  </span>
                </div>
              )}
              <h3 class="text-2xl font-serif font-bold text-primary mb-1 text-center">
                {tier.range}
              </h3>
              <p class="text-center text-gray-500 text-sm mb-4">{tier.description}</p>
              <div class="text-center mb-6">
                <p class="text-xl font-semibold text-[#556B2F]">{tier.label}</p>
              </div>
              <ul class="space-y-2 mb-6">
                {tier.features.map((feature) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-[#556B2F] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-sm text-gray-700">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-3">
            Lo que dicen nuestros clientes
          </h2>
        </div>

        <!-- Testimonials Carousel -->
        <div class="relative max-w-3xl mx-auto">
          <div class="overflow-hidden">
            <div id="testimonials-track" class="flex transition-transform duration-500 ease-in-out">
              {testimonials.map((review) => (
                <div class="min-w-full px-2">
                  <ReviewCard {...review} />
                </div>
              ))}
            </div>
          </div>

          <!-- Arrows -->
          <button id="prev-btn" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-5 bg-white border border-gray-200 shadow-md rounded-full w-10 h-10 flex items-center justify-center text-primary hover:bg-cream transition-colors cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="next-btn" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 bg-white border border-gray-200 shadow-md rounded-full w-10 h-10 flex items-center justify-center text-primary hover:bg-cream transition-colors cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>

          <!-- Dots -->
          <div class="flex justify-center gap-2 mt-6">
            {testimonials.map((_, i) => (
              <button data-dot={i} class={`testimonial-dot w-2.5 h-2.5 rounded-full transition-colors cursor-pointer ${i === 0 ? 'bg-primary' : 'bg-gray-300'}`} />
            ))}
          </div>
        </div>

        <script>
          const track = document.getElementById('testimonials-track');
          const dots = document.querySelectorAll('.testimonial-dot');
          const total = dots.length;
          let current = 0;
          let timer: ReturnType<typeof setInterval>;

          function goTo(index: number) {
            current = (index + total) % total;
            if (track) track.style.transform = `translateX(-${current * 100}%)`;
            dots.forEach((d, i) => {
              d.classList.toggle('bg-primary', i === current);
              d.classList.toggle('bg-gray-300', i !== current);
            });
          }

          function startAuto() {
            timer = setInterval(() => goTo(current + 1), 5000);
          }

          function resetAuto() {
            clearInterval(timer);
            startAuto();
          }

          document.getElementById('prev-btn')?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
          document.getElementById('next-btn')?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
          dots.forEach(d => d.addEventListener('click', () => { goTo(Number(d.getAttribute('data-dot'))); resetAuto(); }));

          startAuto();
        </script>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-8 text-center">
          Preguntas Frecuentes
        </h2>

        <div class="space-y-4">
          <details class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Cuál es el horario de entrega?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Realizamos entregas de lunes a viernes entre las 11:00 y 15:00 hs. Recomendamos pedir con al menos 24 hs de anticipación para garantizar tu lugar y evitar superposiciones con otros pedidos. Si necesitás pedir el mismo día, hacelo con un mínimo de 3 hs de antelación, sujeto a disponibilidad.
            </p>
          </details>

          <details class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Cómo funciona el pedido mínimo?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Trabajamos con empresas de cualquier tamaño. Según el volumen de tu pedido, evaluamos qué plan se ajusta mejor a tu equipo y te lo comunicamos sin compromiso.
            </p>
          </details>

          <details class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Qué métodos de pago aceptan?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Aceptamos transferencia bancaria, Mercado Pago y efectivo. Emitimos Factura C con todos los pedidos corporativos.
            </p>
          </details>

          <details class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm group">
            <summary class="font-semibold text-lg text-primary cursor-pointer list-none flex items-center justify-between">
              ¿Tienen opciones vegetarianas?
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Sí, contamos con opciones vegetarianas dentro de nuestro menú diario. Te recomendamos revisar nuestro <a href="/menu" class="text-primary underline font-medium">menú completo</a> para ver el detalle de los platos disponibles.
            </p>
          </details>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-primary text-cream py-12 md:py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-bold mb-4">
          ¿Listo para alimentar a tu equipo?
        </h2>
        <p class="text-lg mb-6 text-cream/90 max-w-2xl mx-auto">
          Contactanos por WhatsApp y te armamos un presupuesto personalizado para tu empresa
        </p>
        <Button
          href="https://wa.me/5491128240324?text=Hola!%20Soy%20de%20[Empresa].%20Me%20interesa%20el%20servicio%20de%20viandas%20corporativas.%20%C2%BFPodr%C3%ADan%20enviarme%20informaci%C3%B3n%20sobre%20precios%20y%20log%C3%ADstica%3F"
          variant="secondary"
          size="lg"
          class="inline-flex items-center gap-2"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar Presupuesto
        </Button>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton type="b2b" />
</Layout>
