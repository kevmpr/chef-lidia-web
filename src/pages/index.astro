---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import DailySpecialCarousel from '../components/DailySpecialCarousel.astro';
---

<Layout
  title="Catering Peruana y Argentina Premium - Chef Lidia | Parque Patricios, CABA"
  description="Catering profesional de cocina peruana y argentina en Parque Patricios. Viandas corporativas con factura C, menú ejecutivo y especialidades gourmet. Lomo saltado, milanesas premium y más."
>
  <Navbar />

  <main class="bg-cream">
    <!-- Hero Section -->
    <section class="bg-cream py-20 md:py-28 lg:py-32">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <!-- Main headline -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-serif font-bold mb-6 leading-tight text-primary">
            Excelencia Gastronómica<br/>
            <span class="text-primary-dark">para tu Empresa</span>
          </h1>

          <!-- Subheadline -->
          <p class="text-xl md:text-2xl lg:text-3xl mb-6 text-gray-800 font-light leading-relaxed max-w-3xl">
            Especialidades peruanas y argentinas preparadas con ingredientes de calidad
          </p>

          <!-- Value proposition -->
          <p class="text-base md:text-lg mb-10 text-gray-700 leading-relaxed max-w-2xl">
            Ofrecemos soluciones de catering profesional para empresas del Distrito Tecnológico, menú ejecutivo diario y servicio de delivery. Calidad garantizada en cada plato.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <Button href="/empresas" variant="secondary" size="lg" class="shadow-xl hover:shadow-2xl hover:scale-105">
              Soluciones Corporativas
            </Button>
            <Button href="/menu" variant="primary" size="lg" class="border-2 border-primary hover:bg-primary-light shadow-lg hover:shadow-xl hover:scale-105">
              Ver Menú Completo
            </Button>
          </div>

          <!-- Trust indicators -->
          <div class="flex flex-wrap gap-6 text-sm text-gray-600">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Menú Ejecutivo Diario</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Delivery en CABA</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Catering Empresarial</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Daily Specials Carousel -->
    <DailySpecialCarousel />
  </main>

  <Footer />
  <WhatsAppButton type="b2c" />
</Layout>
