---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import homeBg from '../assets/home.png';
import menuData from '../data/menu.json';
import type { MenuData } from '../types/menu';

const menu = menuData as MenuData;
// Carousel: only items from the "menu-del-dia" category that have an image
const dailyMenuCategory = menu.categories.find(c => c.id === 'menu-del-dia');
const carouselItems = (dailyMenuCategory?.items ?? []).filter(item => item.image);

const dishImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/dishes/menu-of-the-day/*', { eager: true });
function getDishImage(imagePath: string | null | undefined): ImageMetadata | null {
  if (!imagePath) return null;
  const filename = imagePath.split('/').pop();
  const key = `/src/assets/dishes/menu-of-the-day/${filename}`;
  return dishImages[key]?.default ?? null;
}
---

<Layout
  title="Chef Lidia y Familia | Cocina Peruana y Argentina - Parque Patricios"
  description="Cocina peruana y argentina con historia. Especialidades del día preparadas desde la cocina de su hogar, ahora en local propio en Parque Patricios. Viandas, almuerzo y cena."
>
  <Navbar />

  <!-- Fixed background — stays static regardless of scroll or content height -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <Image
      src={homeBg}
      alt="Chef Lidia cocina"
      width={1920}
      height={1080}
      class="w-full h-full object-cover object-center blur-sm scale-110"
      loading="eager"
    />
    <div class="absolute inset-0 bg-stone-900/70"></div>
  </div>

  <main>

    <!-- Hero -->
    <section class="relative h-[calc(100vh-6rem)] min-h-[500px] flex flex-col justify-end">
      <div class="px-6 pb-14 md:pb-20 lg:pb-24">
        <div class="container mx-auto max-w-4xl">
          <span class="inline-block text-xs font-semibold tracking-[0.2em] text-white/50 uppercase mb-5">Parque Patricios · Buenos Aires</span>
          <h1 class="text-5xl md:text-7xl lg:text-8xl font-serif font-bold text-white leading-tight mb-5">
            Cocina con historia.<br class="hidden sm:block"/>
            Sabor que se siente.
          </h1>
          <p class="text-lg md:text-xl text-white/75 max-w-2xl leading-relaxed mb-8">
            Especialidades peruanas y argentinas, viandas corporativas y almuerzo de lunes a viernes.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/menu"
              class="inline-flex items-center gap-2 bg-cream/90 hover:bg-cream text-primary px-7 py-3.5 rounded-xl font-semibold transition-all duration-300 shadow-lg"
            >
              Ver Menú
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a
              href="/empresas"
              class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white border border-white/30 hover:border-white/50 px-7 py-3.5 rounded-xl font-semibold transition-all duration-300"
            >
              Servicio Corporativo
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="bg-cream py-4 flex items-center justify-center gap-3">
      <div class="h-px bg-primary/20 flex-1 max-w-xs"></div>
      <div class="flex gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-primary/30"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-primary/30"></span>
      </div>
      <div class="h-px bg-primary/20 flex-1 max-w-xs"></div>
    </div>

    <!-- Especialidades del día -->
    {carouselItems.length > 0 && (
      <section class="relative py-20 md:py-28">

        <div class="px-4 sm:px-6 lg:px-8 mb-12">
          <div class="max-w-5xl mx-auto">
            <span class="inline-block text-xs font-semibold tracking-[0.2em] text-white/50 uppercase mb-3">Hoy en la cocina</span>
            <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-2">Menú del Día</h2>
            <p class="text-white/60">Cada día ofrecemos 2 menús distintos. Consultá disponibilidad por WhatsApp.</p>
          </div>
        </div>

        <!-- Infinite marquee carousel -->
        <div class="overflow-hidden max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pointer-events-none">
          <div class="marquee-track flex gap-4">
            {/* Render items twice for seamless infinite loop */}
            {[...carouselItems, ...carouselItems].map((item, i) => {
              const image = getDishImage(item.image);
              return (
                <div class="marquee-card flex-shrink-0 w-64 md:w-72 group">
                  <div class="relative bg-cream/90 hover:bg-cream rounded-2xl overflow-hidden transition-all duration-300">
                    <div class="absolute top-[-1px] bottom-[-1px] left-0 w-1.5 bg-[#556B2F] z-10"></div>
                    {image && (
                      <div class="aspect-square overflow-hidden">
                        <Image
                          src={image}
                          alt={item.name}
                          width={300}
                          height={300}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                          loading="lazy"
                        />
                      </div>
                    )}
                    <div class="px-5 py-4">
                      <h3 class="text-base font-serif font-bold text-primary">{item.name}</h3>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="px-4 sm:px-6 lg:px-8 mt-10 text-center">
          <a
            href="/menu"
            class="inline-flex items-center gap-2 bg-cream/90 hover:bg-cream text-primary px-7 py-3.5 rounded-xl font-semibold transition-all duration-300 shadow-lg"
          >
            Ver menú completo
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

      </section>
    )}

    <style>
      .marquee-track {
        width: max-content;
        animation: marquee 40s linear infinite;
        padding: 0 1rem;
      }
@keyframes marquee {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
    </style>

  </main>

  <Footer />
  <WhatsAppButton type="b2c" />
</Layout>
