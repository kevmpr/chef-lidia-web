---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MenuCard from '../components/MenuCard.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import menuBg from '../assets/menu.png';
import menuData from '../data/menu.json';
import type { MenuData } from '../types/menu';

const menu = menuData as MenuData;

const dishImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/dishes/*', { eager: true });
function getDishImage(imagePath: string | null | undefined): ImageMetadata | null {
  if (!imagePath) return null;
  const filename = imagePath.split('/').pop();
  const key = `/src/assets/dishes/${filename}`;
  return dishImages[key]?.default ?? null;
}
---

<Layout
  title="Menú - Chef Lidia y Familia | Cocina Peruana y Argentina"
  description="Todo el menú de Chef Lidia y Familia: especialidades peruanas como lomo saltado, arroz chaufa y tallarín saltado, junto a clásicos argentinos. Filtrá por categoría, país o preferencia vegetariana."
>
  <Navbar />

  <!-- Fixed background -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <Image
      src={menuBg}
      alt="Menú Chef Lidia"
      width={1920}
      height={1080}
      class="w-full h-full object-cover object-center blur-sm scale-110"
      loading="eager"
    />
    <div class="absolute inset-0 bg-stone-900/70"></div>
  </div>

  <main>

    <!-- Hero compacto -->
    <section class="relative flex flex-col justify-end h-[38vh] min-h-[260px]">
      <div class="px-6 pb-10 md:pb-14">
        <div class="container mx-auto max-w-5xl">
          <span class="inline-block text-xs font-semibold tracking-[0.2em] text-white/50 uppercase mb-4">Lo que cocinamos</span>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif font-bold text-white leading-tight mb-3">
            Nuestro Menú
          </h1>
          <p class="text-lg text-white/70 max-w-xl leading-relaxed">
            Cocina peruana y argentina preparada con recetas de siempre.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="bg-cream py-4 flex items-center justify-center gap-3">
      <div class="h-px bg-primary/20 flex-1 max-w-xs"></div>
      <div class="flex gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-primary/30"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-primary/30"></span>
      </div>
      <div class="h-px bg-primary/20 flex-1 max-w-xs"></div>
    </div>

    <!-- Filtro mobile: fixed bajo el navbar, colapsable por grupo -->
    <div class="lg:hidden sticky top-20 md:top-24 left-0 right-0 z-40 bg-cream shadow-md">
      <!-- Fila de grupos — scrolleable horizontal -->
      <div class="flex items-stretch border-b border-primary/10">
        <!-- Icono filtro fijo -->
        <div class="flex items-center px-4 border-r border-primary/10 text-primary/50 flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h18M7 10h10M10 16h4"/>
          </svg>
        </div>
        <!-- Grupos arrastrables -->
        <div class="overflow-x-auto scrollbar-hide flex-1">
          <div class="flex w-max">
            <button data-mob-group="cat" class="mob-group-btn whitespace-nowrap py-3.5 px-6 text-xs font-semibold tracking-widest uppercase text-primary/60 hover:text-primary transition-colors">
              Categoría
            </button>
            <button data-mob-group="country" class="mob-group-btn whitespace-nowrap py-3.5 px-6 text-xs font-semibold tracking-widest uppercase text-primary/60 hover:text-primary transition-colors border-x border-primary/10">
              País
            </button>
            <button data-mob-group="veg" class="mob-group-btn whitespace-nowrap py-3.5 px-6 text-xs font-semibold tracking-widest uppercase text-primary/60 hover:text-primary transition-colors">
              Vegetariano
            </button>
          </div>
        </div>
      </div>

      <!-- Opciones — ocultas por defecto, se muestran al tocar un grupo -->
      <div id="mob-opts-cat" class="mob-opts hidden overflow-x-auto scrollbar-hide px-4 py-3 flex gap-2 border-t border-primary/10 bg-cream/95">
        <button data-dish-type="todas"            class="dish-type-btn mob-filter-btn mob-active whitespace-nowrap">Todas</button>
        <button data-dish-type="platos-principales" class="dish-type-btn mob-filter-btn whitespace-nowrap">Platos Principales</button>
        <button data-dish-type="empanadas"        class="dish-type-btn mob-filter-btn whitespace-nowrap">Empanadas</button>
        <button data-dish-type="tartas-tortillas" class="dish-type-btn mob-filter-btn whitespace-nowrap">Tartas y Tortillas</button>
        <button data-dish-type="ensaladas"        class="dish-type-btn mob-filter-btn whitespace-nowrap">Ensaladas</button>
        <button data-dish-type="acompanamientos"  class="dish-type-btn mob-filter-btn whitespace-nowrap">Acompañamientos</button>
      </div>
      <div id="mob-opts-country" class="mob-opts hidden overflow-x-auto scrollbar-hide px-4 py-3 flex gap-2 border-t border-primary/10 bg-cream/95">
        <button data-country="todos"     class="country-btn mob-filter-btn mob-active whitespace-nowrap">Todos</button>
        <button data-country="peru"      class="country-btn mob-filter-btn whitespace-nowrap">Perú</button>
        <button data-country="argentina" class="country-btn mob-filter-btn whitespace-nowrap">Argentina</button>
      </div>
      <div id="mob-opts-veg" class="mob-opts hidden overflow-x-auto scrollbar-hide px-4 py-3 flex gap-2 border-t border-primary/10 bg-cream/95">
        <button data-vegetarian="todos" class="vegetarian-btn mob-filter-btn mob-active whitespace-nowrap">Todos</button>
        <button data-vegetarian="si"    class="vegetarian-btn mob-filter-btn whitespace-nowrap">Vegetariano</button>
      </div>
    </div>


    <!-- Filtros + Grilla -->
    <section class="py-12 md:py-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col lg:flex-row gap-8">

          <!-- Sidebar filtros -->
          <aside id="filter-aside" class="hidden lg:flex sticky top-24 z-40 flex-shrink-0 w-52 h-[calc(100vh-6rem)] items-start">
            <div class="bg-cream/90 rounded-2xl p-7 space-y-8 border-l-[6px] border-[#556B2F] w-full">

              <!-- Categoría -->
              <div>
                <p class="text-xs font-semibold tracking-[0.2em] text-primary/60 uppercase mb-4">Categoría</p>
                <div class="space-y-2">
                  <button data-dish-type="todas"       class="dish-type-btn filter-btn active-filter w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Todas</button>
                  <button data-dish-type="platos-principales" class="dish-type-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Platos Principales</button>
                  <button data-dish-type="empanadas"   class="dish-type-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Empanadas</button>
                  <button data-dish-type="tartas-tortillas" class="dish-type-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Tartas y Tortillas</button>
                  <button data-dish-type="ensaladas"   class="dish-type-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Ensaladas</button>
                  <button data-dish-type="acompanamientos" class="dish-type-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Acompañamientos</button>
                </div>
              </div>

              <!-- País -->
              <div>
                <p class="text-xs font-semibold tracking-[0.2em] text-primary/60 uppercase mb-4">País</p>
                <div class="space-y-2">
                  <button data-country="todos"     class="country-btn filter-btn active-filter w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Todos</button>
                  <button data-country="peru"      class="country-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Perú</button>
                  <button data-country="argentina" class="country-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Argentina</button>
                </div>
              </div>

              <!-- Vegetariano -->
              <div>
                <p class="text-xs font-semibold tracking-[0.2em] text-primary/60 uppercase mb-4">Vegetariano</p>
                <div class="space-y-2">
                  <button data-vegetarian="todos" class="vegetarian-btn filter-btn active-filter w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Todos</button>
                  <button data-vegetarian="si"    class="vegetarian-btn filter-btn w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200">Vegetariano</button>
                </div>
              </div>
            </div>
          </aside>

          <!-- Grilla de platos -->
          <div class="flex-1">
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4" id="menu-grid">
              {menu.categories.map((category) =>
                category.items.map((item) => (
                  <div
                    class="menu-item"
                    data-dish-type={item.dishType || 'otras'}
                    data-is-vegetarian={item.isVegetarian ? 'true' : 'false'}
                    data-country={category.id === 'especialidades-peruanas' ? 'peru' : 'argentina'}
                  >
                    <MenuCard item={item} highlight={item.isDailySpecial} image={getDishImage(item.image)} />
                  </div>
                ))
              )}
            </div>

            <div id="no-results" class="hidden text-center py-12">
              <p class="text-lg text-white/70">No hay platos con esos filtros.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
  <WhatsAppButton type="b2c" />

  <script>
    // Mobile filter group toggle
    document.addEventListener('DOMContentLoaded', () => {
      const groupBtns = document.querySelectorAll('.mob-group-btn');
      const allOpts = document.querySelectorAll('.mob-opts');

      groupBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const group = btn.getAttribute('data-mob-group');
          const target = document.getElementById(`mob-opts-${group}`);
          const isOpen = !target?.classList.contains('hidden');

          // Close all
          allOpts.forEach(o => o.classList.add('hidden'));
          groupBtns.forEach(b => b.classList.remove('mob-group-active'));

          // Toggle this one
          if (!isOpen && target) {
            target.classList.remove('hidden');
            btn.classList.add('mob-group-active');
          }
        });
      });

      // Close options panel when an option is selected
      document.querySelectorAll('.mob-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          allOpts.forEach(o => o.classList.add('hidden'));
          groupBtns.forEach(b => b.classList.remove('mob-group-active'));
        });
      });
    });
  </script>

  <script>
    // Align filter with first grid row when sticky starts; center when scrolling further
    document.addEventListener('DOMContentLoaded', () => {
      const aside = document.getElementById('filter-aside') as HTMLElement | null;
      const card = aside?.querySelector(':scope > div') as HTMLElement | null;
      if (!aside || !card) return;

      const NAVBAR_H = 96; // 6rem

      function update() {
        const available = window.innerHeight - NAVBAR_H;
        const cardH = card.offsetHeight;
        const centeredPad = Math.max(0, (available - cardH) / 2);

        // How far the section has scrolled past the sticky trigger point
        const parentTop = aside.parentElement!.getBoundingClientRect().top;
        const stickyOffset = Math.max(0, NAVBAR_H - parentTop);
        const t = Math.min(stickyOffset / 200, 1);

        aside.style.paddingTop = `${centeredPad * t}px`;
      }

      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    });
  </script>

  <style>
    .filter-btn {
      color: #556B2F;
      background: transparent;
    }
    .filter-btn:hover {
      background: rgba(85,107,47,0.08);
    }
    .filter-btn.active-filter {
      background: #556B2F;
      color: #FDF5E6;
    }
    .mob-filter-btn {
      color: #556B2F;
      background: rgba(85,107,47,0.08);
      border: 1px solid rgba(85,107,47,0.15);
      padding: 6px 14px;
      border-radius: 9999px;
      font-size: 0.875rem;
      font-weight: 500;
      transition: all 0.2s;
    }
    .mob-filter-btn.mob-active {
      background: #556B2F;
      color: #FDF5E6;
      border-color: #556B2F;
    }
    .mob-group-btn.mob-group-active {
      color: #556B2F;
      border-bottom: 2px solid #556B2F;
    }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let activeDishType = 'todas';
      let activeCountry = 'todos';
      let activeVegetarian = 'todos';

      const dishTypeButtons = document.querySelectorAll('.dish-type-btn');
      const countryButtons  = document.querySelectorAll('.country-btn');
      const vegButtons      = document.querySelectorAll('.vegetarian-btn');
      const menuItems       = document.querySelectorAll('.menu-item');
      const noResults       = document.getElementById('no-results');

      function setActive(buttons: NodeListOf<Element>, attr: string, value: string) {
        buttons.forEach(btn => {
          const isActive = btn.getAttribute(attr) === value;
          // Desktop sidebar
          btn.classList.toggle('active-filter', isActive);
          // Mobile pills
          btn.classList.toggle('mob-active', isActive);
        });
      }

      function filterMenu() {
        let visible = 0;
        menuItems.forEach(item => {
          const type  = item.getAttribute('data-dish-type');
          const ctry  = item.getAttribute('data-country');
          const veg   = item.getAttribute('data-is-vegetarian');

          const show =
            (activeDishType === 'todas' || type === activeDishType) &&
            (activeCountry  === 'todos' || ctry === activeCountry) &&
            (activeVegetarian === 'todos' || (activeVegetarian === 'si' && veg === 'true'));

          (item as HTMLElement).style.display = show ? '' : 'none';
          if (show) visible++;
        });
        noResults?.classList.toggle('hidden', visible > 0);
      }

      dishTypeButtons.forEach(btn => btn.addEventListener('click', () => {
        activeDishType = btn.getAttribute('data-dish-type') || 'todas';
        setActive(dishTypeButtons, 'data-dish-type', activeDishType);
        filterMenu();
      }));

      countryButtons.forEach(btn => btn.addEventListener('click', () => {
        activeCountry = btn.getAttribute('data-country') || 'todos';
        setActive(countryButtons, 'data-country', activeCountry);
        filterMenu();
      }));

      vegButtons.forEach(btn => btn.addEventListener('click', () => {
        activeVegetarian = btn.getAttribute('data-vegetarian') || 'todos';
        setActive(vegButtons, 'data-vegetarian', activeVegetarian);
        filterMenu();
      }));

      filterMenu();
    });
  </script>
</Layout>
