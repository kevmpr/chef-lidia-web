---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MenuCard from '../components/MenuCard.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import menuData from '../data/menu.json';
import type { MenuData } from '../types/menu';

const menu = menuData as MenuData;
---

<Layout
  title="Menú - Chef Lidia y Familia | Cocina Peruana y Argentina"
  description="Explorá nuestro menú de comida casera peruana y argentina. Lomo saltado, milanesas, ceviches, empanadas y mucho más. Delivery y takeaway en Parque Patricios."
>
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="bg-cream py-12 md:py-16 border-b-4 border-primary">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-primary mb-4">
          Nuestro Menú
        </h1>
        <p class="text-lg md:text-xl text-gray-700 max-w-2xl mx-auto">
          Descubrí los auténticos sabores de Perú y Argentina. Todos nuestros platos son preparados con ingredientes frescos y recetas tradicionales.
        </p>
      </div>
    </section>

    <!-- Menu Categories -->
    {menu.categories.map((category) => (
      <section class="py-12 md:py-16" id={category.id}>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <!-- Category Header -->
          <div class="text-center mb-10">
            <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-3">
              {category.name}
            </h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
          </div>

          <!-- Category Items Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {category.items.map((item) => (
              <MenuCard item={item} />
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- Call to Action -->
    <section class="bg-primary text-cream py-12">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-bold mb-4">
          ¿Listo para probar nuestros platos?
        </h2>
        <p class="text-lg mb-6 text-cream/90">
          Consultá disponibilidad y hacé tu pedido por WhatsApp
        </p>
        <a
          href="https://wa.me/5491128240324?text=Hola%20Lidia!%20Vi%20el%20men%C3%BA%20en%20la%20web%20y%20me%20gustar%C3%ADa%20hacer%20un%20pedido"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-8 py-4 rounded-lg text-lg font-medium transition-all shadow-lg hover:shadow-xl"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hacer Pedido
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton type="b2c" />
</Layout>
