---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { Image } from 'astro:assets';
import logo from '../assets/cheflidia-logo.png';
---

<Layout
  title="Nosotros - Chef Lidia y Familia | Historia de Comida Casera"
  description="Conocé la historia de Chef Lidia y su familia. Cocina casera peruana y argentina en el corazón de Parque Patricios. Tradición familiar desde el primer día."
>
  <Navbar />

  <main class="bg-cream">
    <!-- Hero Section -->
    <section class="bg-cream py-16 md:py-24">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 text-primary">
          Nuestra Historia
        </h1>
        <p class="text-xl md:text-2xl max-w-3xl mx-auto text-gray-800">
          Una familia unida por el amor a la cocina casera
        </p>
      </div>
    </section>

    <!-- Story Section -->
    <section class="py-16 md:py-20 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-12">
            <!-- Logo/Image -->
            <div class="flex justify-center">
              <div class="bg-white p-8 rounded-lg shadow-xl">
                <Image
                  src={logo}
                  alt="Chef Lidia y Familia"
                  width={300}
                  height={300}
                  class="w-full h-auto"
                />
              </div>
            </div>

            <!-- Story Text -->
            <div>
              <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-6">
                Chef Lidia
              </h2>
              <div class="space-y-4 text-gray-700 leading-relaxed">
                <p>
                  Lidia llegó a Argentina con el sueño de compartir los sabores auténticos de su Perú natal. Con más de 20 años de experiencia en cocina tradicional, decidió junto a su familia crear un espacio donde la comida casera fuera la protagonista.
                </p>
                <p>
                  En <strong>Chef Lidia y Familia</strong>, cada plato cuenta una historia. Desde el lomo saltado que aprendió de su abuela en Lima, hasta las milanesas que perfeccionó al llegar a Buenos Aires, cada receta lleva el sello de la cocina familiar.
                </p>
                <p>
                  Ubicados en el corazón de <strong>Parque Patricios</strong>, nos hemos convertido en el punto de encuentro para quienes buscan comida real, hecha con amor y dedicación. No usamos atajos ni recetas industriales: todo se prepara fresco cada día, tal como lo haríamos en casa.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="py-16 md:py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-4">
            Nuestros Valores
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Los pilares que guían nuestra cocina cada día
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <!-- Value 1: Calidad -->
          <div class="text-center">
            <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-cream" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-primary mb-2">Calidad</h3>
            <p class="text-gray-600">
              Ingredientes frescos seleccionados cada día. Sin atajos, sin conservantes, solo lo mejor.
            </p>
          </div>

          <!-- Value 2: Tradición -->
          <div class="text-center">
            <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-cream" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-primary mb-2">Tradición</h3>
            <p class="text-gray-600">
              Recetas transmitidas de generación en generación, respetando el sabor auténtico.
            </p>
          </div>

          <!-- Value 3: Familia -->
          <div class="text-center">
            <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-cream" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-primary mb-2">Familia</h3>
            <p class="text-gray-600">
              Un emprendimiento familiar donde cada miembro aporta su pasión y dedicación.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Location Section -->
    <section class="py-16 md:py-20 bg-cream">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary mb-4">
          Nos Encontrás en Parque Patricios
        </h2>
        <p class="text-lg text-gray-700 mb-6">
          En el corazón del Distrito Tecnológico de Buenos Aires
        </p>
        <div class="max-w-2xl mx-auto space-y-3">
          <p class="text-gray-700 flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <strong>Av Colonia 95, Parque Patricios, CABA</strong>
          </p>
          <p class="text-gray-700">
            A pocas cuadras de las principales empresas tech y espacios de coworking de la zona.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-primary text-cream py-12 md:py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-bold mb-4">
          ¿Te gustaría probar nuestra comida?
        </h2>
        <p class="text-lg mb-6 text-cream/90 max-w-2xl mx-auto">
          Consultanos por el menú del día o viandas corporativas
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/menu"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg text-lg font-medium transition-all bg-cream-dark hover:bg-cream text-primary border-2 border-primary focus:ring-primary focus:outline-none focus:ring-2 focus:ring-offset-2"
          >
            Ver Menú
          </a>
          <a
            href="/empresas"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg text-lg font-medium transition-all bg-cream-dark hover:bg-cream text-primary border-2 border-primary focus:ring-primary focus:outline-none focus:ring-2 focus:ring-offset-2"
          >
            Viandas Corporativas
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton type="b2c" />
</Layout>
